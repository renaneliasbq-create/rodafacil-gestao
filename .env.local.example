# Supabase — copie do painel do seu projeto em supabase.com
# Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Usado apenas no servidor (Server Actions) — nunca expor no cliente
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Pagar.me — obtenha em dash.pagar.me → Configurações → API
# Sandbox: sk_test_ / pk_test_   |   Produção: sk_live_ / pk_live_
PAGARME_SECRET_KEY=sk_test_SUA_CHAVE_SECRETA_AQUI
NEXT_PUBLIC_PAGARME_PUBLIC_KEY=pk_test_SUA_CHAVE_PUBLICA_AQUI

# Webhook secret — gerado no painel do Pagar.me ao criar o webhook
PAGARME_WEBHOOK_SECRET=SUA_WEBHOOK_SECRET_AQUI

# URL base do app (usado para redirecionamentos de auth)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Pagar.me — obtenha em dash.pagar.me → Configurações → API
# Sandbox: sk_test_ / pk_test_   |   Produção: sk_live_ / pk_live_
PAGARME_SECRET_KEY=sk_test_SUA_CHAVE_SECRETA_AQUI
NEXT_PUBLIC_PAGARME_PUBLIC_KEY=pk_test_SUA_CHAVE_PUBLICA_AQUI

# Webhook secret — gerado no painel do Pagar.me ao criar o webhook
PAGARME_WEBHOOK_SECRET=SUA_WEBHOOK_SECRET_AQUI
